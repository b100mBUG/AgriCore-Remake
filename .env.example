# ── Database ───────────────────────────────────────────────────────────────────
# Development: SQLite (no setup needed)
DATABASE_URL=sqlite+aiosqlite:///./agricore_dev.db
# Production: PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/agricore

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security ───────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080     # 7 days

# Admin login — single admin account for this MVP.
# Generate ADMIN_PASSWORD_HASH once with:
#   python -c "from app.core.security import hash_password; print(hash_password('your-password'))"
# Never put a plain-text password in this file.
ADMIN_EMAIL=admin@agricore.co.ke
ADMIN_PASSWORD_HASH=

# ── AI ─────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ── Weather ────────────────────────────────────────────────────────────────────
WEATHER_API_KEY=

# ── Cloudinary ─────────────────────────────────────────────────────────────────
CLOUDINARY_API_SECRET=
CLOUDINARY_API_KEY=
CLOUDINARY_CLOUD_NAME=

# ── Crawler ────────────────────────────────────────────────────────────────────
CRAWL_INTERVAL_HOURS=24          # how often to re-crawl seed URLs
CLASSIFY_INTERVAL_MINUTES=60     # how often to run the AI classifier
MAX_CRAWL_PAGES_PER_RUN=100      # cap per crawl cycle
CLASSIFIER_CONFIDENCE_THRESHOLD=0.70   # cards below this go to review

# ── CORS ───────────────────────────────────────────────────────────────────────
# Set to your actual frontend origin(s), comma-separated. Leaving this as "*"
# (or unset) makes origins_list return [] — CORS will then block every
# cross-origin browser request rather than silently being wide open.
# Example: ALLOWED_ORIGINS=https://app.agricore.co.ke,https://admin.agricore.co.ke
ALLOWED_ORIGINS=*

# ── Rate Limiting ──────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60         # requests per IP per minute

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development              # development | production
APP_VERSION=1.0.0
